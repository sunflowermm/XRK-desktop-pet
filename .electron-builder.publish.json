{
  "appId": "com.sunflower.desktop-pet",
  "productName": "向日葵桌面宠物",
  "copyright": "Copyright © 2026 sunflower",
  "directories": {
    "output": "dist",
    "buildResources": "."
  },
  "files": [
    "**/*",
    "!**/*.md",
    "!**/test/**/*",
    "!**/.user-data/**/*",
    "!dist/**/*",
    "!.git/**/*"
  ],
  "win": {
    "executableName": "向日葵桌面宠物",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "assets/icon.ico",
    "requestedExecutionLevel": "asInvoker"
  },
  "extraResources": [
    {
      "from": "assets/icon.ico",
      "to": "assets/icon.ico"
    }
  ],
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "向日葵桌面宠物",
    "deleteAppDataOnUninstall": false
  },
  "extraMetadata": {
    "main": "main.js",
    "xrkUpdateSource": {
      "platform": "github",
      "provider": "github",
      "url": null,
      "owner": "sunflowermm",
      "repo": "XRK-desktop-pet",
      "releasesUrl": "https://github.com/sunflowermm/XRK-desktop-pet/releases",
      "embeddedAt": "2026-03-06T12:23:08.925Z"
    }
  },
  "publish": {
    "provider": "github",
    "owner": "sunflowermm",
    "repo": "XRK-desktop-pet",
    "releaseType": "release",
    "publishAutoUpdate": true
  }
}